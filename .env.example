# ─── Frontend (set in Netlify / hosting build environment) ───────────────────
# Required for production: your live backend API base URL (include /api)
VITE_API_URL=https://your-backend-host.com/api

# Google Drive folder for resource downloads (optional)
VITE_RESOURCES_DRIVE_URL=https://drive.google.com/drive/folders/YOUR_FOLDER_ID

# WhatsApp community (shown in resource access modal + SMS)
VITE_WHATSAPP_COMMUNITY_URL=https://chat.whatsapp.com/YOUR_INVITE_CODE

# Public contact (optional — used in Hero, Footer, Contact)
VITE_CONTACT_WHATSAPP=233506626068

# AgriLync mobile app (optional — when live, enables store buttons on farmer signup prompt)
VITE_APP_STORE_URL=
VITE_PLAY_STORE_URL=
VITE_CONTACT_PHONE_SECONDARY=233247552111
VITE_CONTACT_EMAIL=agrilync@gmail.com

# Supabase (anon key is public; keep project URL + key in env, not in source)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Backend (.env in /backend) ─────────────────────────────────────────────
PORT=5001
# Use 5001 if another app (e.g. another API) already uses 5000 on your machine
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/agrilync

# Required on Render for blog/resource cover images (disk uploads are wiped on restart)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Must match your deployed frontend URL exactly (no trailing slash)
FRONTEND_URL=https://www.agrilyncnexus.com

JWT_SECRET=your-long-random-secret
REFRESH_TOKEN_SECRET=your-other-long-random-secret

# One-time seed scripts only — never commit real values
BLOG_ADMIN_PASSWORD=
BLOG_ADMIN_EMAIL=admin@agrilync.com
BLOG_BLOGGER_PASSWORD=
BLOG_BLOGGER_EMAIL=raphmawuli.agrilync@gmail.com
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_EMAIL=
AGENT_PASSWORD=
AGENT_SEED_EMAIL=
FIELD_AGENT_SEED_PASSWORD=

# Optional: email blast when publishing blogs
RESEND_API_KEY=
RESEND_FROM_EMAIL=Agrilync Nexus <noreply@agrilync.com>

# mNotify SMS (resource access welcome messages)
MNOTIFY_API_KEY=
MNOTIFY_SENDER_ID=AgriLync

# WhatsApp community link included in resource-access SMS
WHATSAPP_COMMUNITY_URL=https://chat.whatsapp.com/YOUR_INVITE_CODE
